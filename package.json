{
  "name": "qq-shot",
  "version": "0.1.0",
  "description": "A minimal QQ-like screenshot tool for macOS built with Electron.",
  "productName": "可鑫的截屏小工具",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:native-helper": "cd native-swift && xcodegen generate && xcodebuild -project QQShotNative.xcodeproj -scheme QQShotCaptureCLI -configuration Debug CONFIGURATION_BUILD_DIR=\"$PWD/local-build\" build",
    "dist:mac": "npm run build:native-helper && electron-builder --mac dir"
  },
  "build": {
    "appId": "com.apple.qq-shot",
    "productName": "可鑫的截屏小工具",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "native-swift/local-build/QQShotCaptureCLI",
        "to": "native/QQShotCaptureCLI"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.utilities",
      "target": [
        "dir"
      ],
      "artifactName": "${productName}.app"
    }
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.0.12"
  }
}
